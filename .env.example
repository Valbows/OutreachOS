# ===========================================
# OutreachOS Environment Variables
# ===========================================

# --- Neon Database ---
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- Neon Auth ---
NEON_AUTH_BASE_URL=https://auth.xxx.neon.tech
NEON_AUTH_COOKIE_SECRET=your-cookie-secret-min-32-chars-here

# --- OAuth (Production) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Resend (Email Delivery) ---
RESEND_API_KEY=re_xxx
RESEND_WEBHOOK_SECRET=whsec_xxx

# --- Hunter.io (Contact Enrichment) ---
HUNTER_API_KEY=

# --- Gemini (LLM) ---
GEMINI_API_KEY=

# --- OpenRouter (LLM Fallback) ---
OPENROUTER_API_KEY=

# --- MCP Server ---
MCP_PORT=3001

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
