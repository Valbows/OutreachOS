{
  "name": "@outreachos/mcp-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsup src/server.ts src/stdio.ts --format esm --dts",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest run",
    "start": "node dist/server.js",
    "start:stdio": "node dist/stdio.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@outreachos/db": "workspace:*",
    "@outreachos/services": "workspace:*",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.44.0",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "5.9.2",
    "vitest": "^3.0.0"
  }
}
