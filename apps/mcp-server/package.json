{
  "name": "@outreachos/mcp-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsup src/server.ts src/stdio.ts --format esm --dts",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest run",
    "start": "node dist/server.js",
    "start:stdio": "node dist/stdio.js"
  },
  "dependencies": {
    "@outreachos/db": "workspace:*",
    "@outreachos/services": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "5.9.2",
    "vitest": "^3.0.0"
  }
}
