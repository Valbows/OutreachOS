{
  "name": "@outreachos/services",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@outreachos/db": "workspace:*",
    "drizzle-orm": "^0.44.0",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "5.9.2",
    "vitest": "^3.0.0"
  }
}
